{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=marketdata;Username=postgres;Password=postgres"
  },
  "Database": {
    "ConnectionStringName": "Postgres",
    "EnsureCreated": true,
    "InitializationRetryCount": 20,
    "InitializationRetryDelayMilliseconds": 1000
  },
  "Pipeline": {
    "RawChannelCapacity": 10000,
    "TickChannelCapacity": 10000,
    "NormalizerWorkerCount": 2
  },
  "Persistence": {
    "BatchSize": 250,
    "FlushIntervalMilliseconds": 500,
    "FailedFlushDelayMilliseconds": 1000
  },
  "Deduplication": {
    "TtlSeconds": 60,
    "CleanupIntervalSeconds": 5
  },
  "Exchanges": {
    "Binance": {
      "Enabled": true,
      "Url": "wss://stream.binance.com:9443/ws/btcusdt@trade",
      "ReconnectDelaySeconds": 5,
      "ReceiveBufferSize": 8192
    },
    "Bybit": {
      "Enabled": true,
      "Url": "wss://stream.bybit.com/v5/public/spot",
      "ReconnectDelaySeconds": 5,
      "ReceiveBufferSize": 8192,
      "Subscriptions": [
        "{\"op\":\"subscribe\",\"args\":[\"publicTrade.BTCUSDT\"]}"
      ]
    },
    "Kraken": {
      "Enabled": true,
      "Url": "wss://ws.kraken.com/v2",
      "ReconnectDelaySeconds": 5,
      "ReceiveBufferSize": 8192,
      "Subscriptions": [
        "{\"method\":\"subscribe\",\"params\":{\"channel\":\"trade\",\"symbol\":[\"BTC/USD\"]}}"
      ]
    }
  }
}
